---
import Logo from './Logo.astro'
import Themetoggle from './Themetoggle.astro'
---
 
<header>
  <div class="flex justify-between">
    <Logo />
    <Themetoggle />
  </div>
  <div class="flex items-center mt-2">
    <span class="text-2xl font-extrabold mr-1">却惑</span>
    <span class="text-2xl text-transparent font-extrabold bg-clip-text bg-gradient-to-r from-#62baf0 to-#44956f">几菩提</span>
    <!-- 更新告示浮动小圆点 -->
    <span id="update-dot" class="update-dot" title="查看更新告示">●</span>
  </div>
  <p mt-8 op-45>菩提本无树，明镜亦非台</p><p mt-2 op-45>本来无一物，何处惹尘埃</p>
  <script src="https://unpkg.com/turndown/dist/turndown.js"></script>
</header>
 
<!-- 更新告示弹窗 -->
<div id="update-modal" class="update-modal hidden">
  <div class="update-modal-backdrop"></div>
  <div class="update-modal-content">
    <div class="update-modal-header">
      <span>🙏 2026/06/30 更新告示</span>
      <button id="update-modal-close" class="update-modal-close">✕</button>
    </div>
    <div class="update-modal-body">
      <h3>🪔 角色Prompt升级</h3>
      <p>重写四位角色（佛陀、禅师、小沙弥、禅机）的系统提示词，摒弃粗暴的反越狱前缀，打造专属语言风格与行为准则：</p>
      <ul>
        <li><strong>佛陀</strong>：庄严慈悲，善用佛经偈颂，以无量慈悲包容众生</li>
        <li><strong>禅师</strong>：机锋棒喝，以公案话头斩断妄想，留白即是禅</li>
        <li><strong>小沙弥</strong>：天真质朴，以初学者之眼观佛法，接地气而不失赤诚</li>
        <li><strong>禅机</strong>：极简至极，一语破迷，以反问与悖论直指人心</li>
      </ul>
 
      <h3>🪔 模型升级</h3>
      <p>默认模型由 DeepSeek-V3 升级为更适配角色扮演场景的方案：</p>
      <ul>
        <li><strong>硅基流动</strong>：切换至 Qwen3-235B，中文文学表达更强，角色一致性更稳</li>
        <li><strong>302.AI</strong>：切换至 Claude Sonnet，角色扮演能力更强，长对话不崩人设</li>
      </ul>
<h3>🪔 其他</h3>
      <p>其他细节微调与优化</p>
    </div>
  </div>
</div>
 
<style>
  /* 浮动跳跃小圆点 */
  .update-dot {
    position: relative;
    top: -14px;
    right: 2px;
    font-size: 10px;
    color: #c8963e;
    cursor: pointer;
    animation: bounce-dot 1.4s ease-in-out infinite;
    z-index: 10;
    text-shadow: 0 0 4px #d4a94c88, 0 0 8px #c8963e55;
    transition: color 0.2s;
  }
  .update-dot:hover {
    color: #e0b35a;
    text-shadow: 0 0 6px #d4a94ccc, 0 0 12px #c8963e88;
  }
  @keyframes bounce-dot {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-6px); }
  }
 
  /* 弹窗遮罩 */
  .update-modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 9998;
  }
 
  /* 弹窗主体 */
  .update-modal-content {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    z-index: 9999;
    width: min(440px, 90vw);
    max-height: 80vh;
    overflow-y: auto;
    background: var(--c-bg);
    color: var(--c-fg);
    border-radius: 12px;
    box-shadow: 0 8px 32px rgba(0,0,0,0.25);
    border: 1px solid #c8963e44;
    padding: 0;
  }
 
  /* 弹窗头部 */
  .update-modal-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 16px 20px 12px;
    border-bottom: 1px solid #c8963e33;
    font-size: 18px;
    font-weight: 700;
  }
  .update-modal-close {
    background: none;
    border: none;
    font-size: 18px;
    cursor: pointer;
    color: var(--c-fg);
    opacity: 0.5;
    transition: opacity 0.2s;
    padding: 0 4px;
  }
  .update-modal-close:hover {
    opacity: 1;
  }
 
  /* 弹窗内容 */
  .update-modal-body {
    padding: 16px 20px 24px;
    font-size: 14px;
    line-height: 1.75;
  }
  .update-modal-body h3 {
    font-size: 15px;
    font-weight: 700;
    margin: 12px 0 6px;
    color: #c8963e;
  }
  .update-modal-body h3:first-child {
    margin-top: 0;
  }
  .update-modal-body ul {
    padding-left: 20px;
    margin: 6px 0 12px;
  }
  .update-modal-body li {
    margin: 4px 0;
  }
  .update-modal-body p {
    margin: 4px 0 8px;
    opacity: 0.85;
  }
 
  .hidden {
    display: none !important;
  }
</style>
 
<script>
  // 记录已读状态，同一个用户只弹一次
  const UPDATE_KEY = 'update_notice_read_20250629';
  const dot = document.getElementById('update-dot');
  const modal = document.getElementById('update-modal');
  const closeBtn = document.getElementById('update-modal-close');
  const backdrop = modal?.querySelector('.update-modal-backdrop');
 
  const showModal = () => {
    modal?.classList.remove('hidden');
  };
  const hideModal = () => {
    modal?.classList.add('hidden');
    localStorage.setItem(UPDATE_KEY, 'read');
  };
 
  dot?.addEventListener('click', showModal);
  closeBtn?.addEventListener('click', hideModal);
  backdrop?.addEventListener('click', hideModal);
 
  // 首次访问自动弹出
  if (!localStorage.getItem(UPDATE_KEY)) {
    setTimeout(showModal, 800);
  }
</script>
